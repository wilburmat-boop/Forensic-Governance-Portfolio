@charset "utf-8";

body { margin-top: 0px; margin-left: 0px; margin-right: 0px; color: rgb(0, 0, 0); font-family: Tahoma, Arial, Helvetica, sans-serif; font-size: 9pt; background-color: white; }

a.block:link, a.block:visited { color: rgb(63, 102, 153); font-style: normal; font-weight: bold; font-size: 9pt; text-decoration: none; text-align: center; background-color: rgb(224, 231, 239); padding: 4px; width: 142px; height: 22px; border: 1px solid rgb(204, 204, 204); }

a.block:hover, a.block:active { color: rgb(202, 121, 0); font-style: normal; font-weight: bold; font-size: 9pt; text-decoration: underline; text-align: center; background-color: rgb(224, 231, 239); padding: 4px; width: 142px; height: 22px; border: 1px solid rgb(204, 204, 204); }

.tilebanner { background: url("banner/banner_tile.jpg") repeat-x rgb(255, 255, 255); }

img { border-width: 0px; }

.heading2 { font-size: 10pt; color: rgb(0, 0, 0); font-family: Tahoma, Arial, Helvetica, sans-serif; font-weight: bold; }

